{
  "name": "vscode-jst",
  "displayName": "JST Templates",
  "description": "Syntax highlighting, diagnostics, and navigation for JST templates (<script type=\"jst\">).",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": ["Programming Languages", "Linters"],
  "activationEvents": ["onLanguage:html"],
  "main": "./src/extension.js",
  "contributes": {
    "grammars": [
      {
        "scopeName": "jst.injection",
        "path": "./syntaxes/jst.injection.tmLanguage.json",
        "injectTo": ["text.html.basic", "text.html.derivative"]
      },
      {
        "scopeName": "jst.islands",
        "path": "./syntaxes/jst.islands.tmLanguage.json",
        "injectTo": ["text.html.basic", "text.html.derivative"],
        "embeddedLanguages": {
          "meta.embedded.jst.expression": "javascript",
          "meta.embedded.jst.code": "javascript"
        }
      }
    ]
  },
  "scripts": {
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.1.0"
  }
}
